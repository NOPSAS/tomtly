{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(vercel --prod*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Users/jakob/tomtly && npm run build 2>&1 | tail -3 | grep -q 'prerendered as static' && echo 'Build OK' || (echo 'BLOCK: Build feilet - fiks feilene først' && exit 1)"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(vercel *)",
      "Bash(curl *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(cp *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(git *)"
    ]
  }
}
